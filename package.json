{
  "name": "tools-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:backend": "npm run dev --prefix ../tools-hub-backend",
    "dev:all": "npm run dev --prefix ../tools-hub-backend & npm run dev",
    "setup:payments": "node scripts/setup-payments.mjs",
    "stripe:bootstrap": "node scripts/stripe-bootstrap.mjs",
    "stripe:webhook": "stripe listen --forward-to localhost:3000/api/billing/webhook --events checkout.session.completed,customer.subscription.updated,customer.subscription.deleted,invoice.payment_failed",
    "payments:check": "node scripts/check-payments.mjs",
    "brand:check": "node scripts/check-brand.mjs",
    "build": "next build",
    "build:backend": "npm run build --prefix ../tools-hub-backend",
    "start": "next start",
    "start:backend": "npm run start --prefix ../tools-hub-backend",
    "lint": "eslint"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.4.2",
    "hash-wasm": "^4.12.0",
    "heic2any": "^0.0.4",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "js-md4": "^0.3.2",
    "js-yaml": "^4.2.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "next": "16.2.7",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
